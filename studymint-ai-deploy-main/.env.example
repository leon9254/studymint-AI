# Image source
GHCR_OWNER=your-github-username-or-org
IMAGE_TAG=latest

# Public port exposed by the frontend Nginx container
APP_PORT=8080
FRONTEND_BIND=0.0.0.0

# Database
POSTGRES_USER=studymint
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=studymint

# Backend application settings
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:8080
BACKEND_CORS_ORIGIN_REGEX=
BACKEND_PUBLIC_URL=http://backend:8000
FRONTEND_PUBLIC_URL=http://localhost:8080
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Email verification and password reset SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=info@marketing.ainexis.tech
SMTP_PASSWORD=replace-with-hostinger-email-password
SMTP_FROM_EMAIL=info@marketing.ainexis.tech
SMTP_FROM_NAME=StudyMint AI
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.5
OPENAI_GUARDRAIL_MODEL=gpt-4.1-mini
OPENAI_GUARDRAIL_MAX_OUTPUT_TOKENS=12000
OPENAI_REASONING_EFFORT=high
OPENAI_TEXT_VERBOSITY=medium
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_OUTPUT_TOKENS=24000
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_BACKOFF_SECONDS=2.0

# Stuvia agent and n8n review handoff
STUVIA_AGENT_DEFAULT_PROFILE_URL=https://www.stuvia.com/user/casewritters
STUVIA_SCRAPE_TIMEOUT_SECONDS=15
STUVIA_SCRAPE_PAGE_LIMIT=14
STUVIA_AGENT_MAX_CONCURRENCY=10
STUVIA_AGENT_GENERATION_ATTEMPTS=3
STUVIA_AGENT_RECOVERY_CONCURRENCY=1
STUVIA_AGENT_RETRY_BACKOFF_SECONDS=2.0
STUVIA_AGENT_USE_LLM_RANKER=false
STUVIA_AGENT_FAST_BATCH_SIZE=30
N8N_STUVIA_WEBHOOK_TIMEOUT_SECONDS=45
N8N_STUVIA_WEBHOOK_URL=
N8N_STUVIA_WEBHOOK_TOKEN=replace-with-a-long-random-stuvia-token

# Optional n8n runtime, started with: docker compose --profile automation up -d n8n
N8N_IMAGE_TAG=1.98.2
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_PUBLIC_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=replace-with-a-long-random-n8n-key
N8N_RUNNERS_ENABLED=true
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-a-strong-password
N8N_BIND=127.0.0.1
N8N_PORT=5678
STUVIA_BROWSER_PUBLISHER_URL=http://stuvia-publisher:8787/publish/async
STUVIA_LOGIN_URL=https://www.stuvia.com/login
STUVIA_UPLOAD_URL=https://www.stuvia.com/upload
STUVIA_DEFAULT_COUNTRY=United States
STUVIA_DEFAULT_INSTITUTION=Galen College of Nursing
STUVIA_DEFAULT_PRICE=9.99
STUVIA_MIN_PRICE=4.99
STUVIA_MAX_PRICE=24.99
STUVIA_PUBLISHER_DRY_RUN=false
STUVIA_PUBLISHER_HEADLESS=true
STUVIA_PUBLISHER_NAVIGATION_TIMEOUT_MS=30000
STUVIA_PUBLISHER_FORM_TIMEOUT_MS=10000
STUVIA_PUBLISHER_LISTING_TIMEOUT_SECONDS=150
STUVIA_PUBLISHER_FILESTACK_TIMEOUT_SECONDS=45

# Exports
PDF_EXPORT_BASE_URL=/exports
PDF_EXPORT_DIR=/app/exports
