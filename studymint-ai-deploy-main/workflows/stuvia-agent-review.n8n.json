    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { ok: true, run_id: $json.run_id, review_required: $json.review_required, auto_publish_requested: $json.auto_publish_requested, manual_publish_requested: $json.manual_publish_requested, posting_policy: $json.posting_policy } }}",
        "options": {}
      },
      "id": "49e44012-fb87-4c39-bac0-90b7cb138c93",
      "name": "Respond to StudyMint",
